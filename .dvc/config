[core]
    remote = gdrive
    autostage = true

['remote "gdrive"']
    url = gdrive://your-folder-id
    # To use Google Drive as free DVC remote:
    # 1. Create a folder in Google Drive
    # 2. Get the folder ID from the URL
    # 3. Replace 'your-folder-id' above
    # 4. Run: dvc push

['remote "local"']
    url = /tmp/dvc-storage
