# Broker Configuration
MT5_LOGIN=your_login
MT5_PASSWORD=your_password
MT5_SERVER=your_server
MT5_PATH=/path/to/terminal64.exe

# IBKR (alternative)
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=1

# API Keys
WANDB_API_KEY=your_wandb_key
TELEGRAM_BOT_TOKEN=your_telegram_token
TELEGRAM_CHAT_ID=your_chat_id
# Note: GDELT requires no API key. FT.com sitemap scraping requires no key.

# FT.com Cookie String (for article body extraction behind paywall)
# Get from: Chrome DevTools → Application → Cookies → ft.com → copy all as string
# Format: "FTSession=abc123; spoor-id=xyz789; ..."
FT_COOKIE_STRING=

# Database
DUCKDB_PATH=data/ticks.duckdb
SQLITE_PATH=data/trades.sqlite

# Deployment
ENVIRONMENT=development
LOG_LEVEL=INFO
INFERENCE_DEVICE=cpu
